##############################################
# Security group — explicit inbound AND outbound rules
##############################################

resource "aws_security_group" "vm" {
  name        = "${var.name_prefix}-sg"
  description = "Example VM security group: SSH/HTTP/HTTPS in, everything out"
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = [var.allowed_ssh_cidr]
  }

  egress {
    description = "All outbound traffic"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = var.tags
}

##############################################
# SSH key pair — generated by Terraform so there's no manual step
# before the first apply (private key retrieved via `terraform output`)
##############################################

resource "tls_private_key" "vm" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "vm" {
  key_name   = "${var.name_prefix}-key"
  public_key = tls_private_key.vm.public_key_openssh
}

##############################################
# The VM itself
##############################################

resource "aws_instance" "vm" {
  ami                         = data.aws_ami.amazon_linux.id
  instance_type               = var.instance_type
  subnet_id                   = data.aws_subnets.default.ids[0]
  vpc_security_group_ids      = [aws_security_group.vm.id]
  key_name                    = aws_key_pair.vm.key_name
  associate_public_ip_address = true

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-vm"
  })
}
